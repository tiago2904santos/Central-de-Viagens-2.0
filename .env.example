DJANGO_SECRET_KEY=sua-chave-secreta-aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — banco padrão em desenvolvimento (obrigatório para runserver)
# Sem estas variáveis, o projeto usa SQLite (apenas para testes ou fallback local)
POSTGRES_DB=central_viagens
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# OSRM local para rotas reais sem custo por requisicao
OSRM_ENABLED=false
OSRM_BASE_URL=http://localhost:5000
OSRM_TIMEOUT_SECONDS=8

# Google OAuth / Drive (por usuario)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/integracoes/google-drive/callback/
# Gere uma chave Fernet com:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=
